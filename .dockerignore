# Keep the build context small and secrets out of the image.
.git/
.github/
.venv/
venv/
__pycache__/
**/__pycache__/
*.pyc

# Secrets + runtime data (regenerated; never bake into the image)
.env
cloud_audit.jsonl
companion.db*
chroma_db/
*.log
backups/

# Node / build artifacts (frontend is rebuilt inside the image)
frontend/node_modules/
frontend/dist/
frontend/public/vad/
whatsapp-bridge/

# Heavy personal voice data — never part of the lite image
voice_tracks/
rvc_dataset/
voices/
songs/
applio/
media/tts/
media/bench/

# Editor / OS
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db
