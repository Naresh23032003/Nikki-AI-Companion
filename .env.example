# Copy this file to .env and fill in your own values (.env is gitignored).

# Cloud "big brain" API keys.
# Primary: Groq free tier (https://console.groq.com)
GROQ_API_KEY=
# Fallbacks (enable in config.yaml brain.providers):
GEMINI_API_KEY=
CEREBRAS_API_KEY=

# Auto-accept Coqui XTTS license (CPML, personal/non-commercial use)
COQUI_TOS_AGREED=1

# LAN auth: non-localhost clients must send this token
# (open the PWA once with ?token=<value>). Generate any random hex string.
COMPANION_AUTH_TOKEN=
